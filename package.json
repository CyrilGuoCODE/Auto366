{
  "name": "auto366",
  "version": "0.9.5",
  "description": "天学网自动化答题工具，支持各类题型答案获取和自动填写",
  "main": "main.js",
  "author": "Auto366",
  "license": "GNUV3",
  "repository": {
    "type": "git",
    "url": "https://github.com/cyrilguocode/Auto366.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win --publish never"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "archiver": "^7.0.1",
    "bootstrap-icons": "^1.13.1",
    "electron-updater": "^6.7.3",
    "form-data": "^4.0.5",
    "fs": "^0.0.1-security",
    "fs-extra": "^11.1.1",
    "http-mitm-proxy": "^1.1.0",
    "node-stream-zip": "^1.15.0",
    "path": "^0.12.7",
    "posthog-node": "^5.21.2",
    "supabase-js": "^0.0.1-security",
    "uuid": "^11.1.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-updater": "^6.7.3"
  },
  "build": {
    "appId": "com.auto366.app",
    "productName": "Auto366",
    "electronLanguages": ["zh-CN"],
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!.http-mitm-proxy/**/*",
      "!.trae/**/*",
      "!.vscode/**/*",
      "!answers/**/*",
      "!dist/**/*",
      "!temp/**/*",
      "!file/**/*",
      "!.git/**/*",
      "!web/**/*",
      "!resources/tun/**/*",
      "!resources/openspeedy/**/*",
      "!resources/tts/**/*"
    ],
    "extraResources": [
      {
        "from": "./resources/Auto366CompatibilityMode.ps1",
        "to": "../"
      },
      {
        "from": "./resources/init.mp3",
        "to": "../"
      },
      {
        "from": "./resources/tun",
        "to": "tun"
      },
      {
        "from": "./resources/openspeedy",
        "to": "openspeedy"
      },
      {
        "from": "./resources/tts",
        "to": "tts"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "installerLanguages": [
        "zh_CN"
      ],
      "language": "2052"
    },
    "publish": {
      "provider": "github",
      "owner": "cyrilguocode",
      "repo": "Auto366"
    }
  }
}
